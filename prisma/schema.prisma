generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  passwordHash     String
  name             String?
  avatar           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subscriptions    Subscription[]
  episodePurchases EpisodePurchase[]
  watchHistory     WatchHistory[]
  adImpressions    AdImpression[]
  payments         Payment[]

  @@map("user")
}

model Series {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  image       String?
  tags        String?
  type        String?
  views       Int       @default(0)
  status      String
  isExclusive Boolean   @default(false)
  hasAds      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[]

  @@map("series")
}

model Episode {
  id               Int               @id @default(autoincrement())
  seriesId         Int
  episodeNumber    Int
  title            String
  videoUrl         String
  thumbnailUrl     String?
  duration         Int
  status           String
  isExclusive      Boolean?
  hasAds           Boolean?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  series           Series            @relation(fields: [seriesId], references: [id])
  episodePurchases EpisodePurchase[]
  watchHistory     WatchHistory[]
  adImpressions    AdImpression[]

  @@unique([seriesId, episodeNumber])
  @@index([seriesId])
  @@map("episode")
}

model Plan {
  id            Int            @id @default(autoincrement())
  name          String
  price         Decimal
  currency      String
  durationDays  Int
  isActive      Boolean        @default(true)
  subscriptions Subscription[]

  @@map("plan")
}

model Subscription {
  id      Int      @id @default(autoincrement())
  userId  Int
  planId  Int
  startAt DateTime
  endAt   DateTime
  status  String
  user    User     @relation(fields: [userId], references: [id])
  plan    Plan     @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@map("subscription")
}

model EpisodePurchase {
  id          Int      @id @default(autoincrement())
  userId      Int
  episodeId   Int
  price       Decimal
  currency    String
  purchasedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  episode     Episode  @relation(fields: [episodeId], references: [id])

  @@unique([userId, episodeId])
  @@index([episodeId])
  @@map("episodepurchase")
}

model WatchHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  episodeId     Int
  progress      Int
  lastWatchedAt DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
  episode       Episode  @relation(fields: [episodeId], references: [id])

  @@unique([userId, episodeId])
  @@index([episodeId])
  @@map("watchhistory")
}

model AdUnit {
  id             Int            @id @default(autoincrement())
  name           String
  googleAdUnitId String
  placement      String
  isActive       Boolean        @default(true)
  adImpressions  AdImpression[]

  @@map("adunit")
}

model AdImpression {
  id           Int      @id @default(autoincrement())
  userId       Int?
  episodeId    Int?
  adUnitId     Int
  impressionAt DateTime @default(now())
  device       String?
  country      String?
  user         User?    @relation(fields: [userId], references: [id])
  episode      Episode? @relation(fields: [episodeId], references: [id])
  adUnit       AdUnit   @relation(fields: [adUnitId], references: [id])

  @@index([userId])
  @@index([episodeId])
  @@index([adUnitId])
  @@map("adimpression")
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Decimal
  currency  String
  method    String
  status    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payment")
}

model Setting {
  key   String @id
  value String

  @@map("setting")
}
